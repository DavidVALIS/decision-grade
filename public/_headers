# Cloudflare Pages cache headers
# Reference: https://developers.cloudflare.com/pages/configuration/headers/

# Next.js fingerprinted assets are immutable.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# AI-readable bundles — short cache so updates propagate.
# Regenerated by the GitHub Action on every .mdx change.
/llms.txt
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/plain; charset=utf-8

/llms-full.txt
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/plain; charset=utf-8

# Search index — short cache, served as JSON.
/search-index.json
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: application/json; charset=utf-8

# API endpoints (Pages Functions) — never cached, CORS already set in handler.
/api/*
  Cache-Control: no-store

# HTML pages — short cache with revalidation so deploys propagate quickly.
/*
  Cache-Control: public, max-age=60, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
